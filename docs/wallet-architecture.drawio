                    <mxGeometry x="760" y="500" width="170" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="success" value="succeeded&#xa;TERMINAL" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="m1" vertex="1">
                    <mxGeometry x="1050" y="170" width="170" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="failed" value="failed&#xa;TERMINAL" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" parent="m1" vertex="1">
                    <mxGeometry x="1050" y="300" width="170" height="80" as="geometry"/>
                </mxCell>
