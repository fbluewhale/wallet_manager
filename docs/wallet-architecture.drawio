    <diagram id="data-model" name="4. Persistence Model">
        <mxGraphModel dx="2920" dy="933" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
            <root>
                <mxCell id="d0"/>
                <mxCell id="d1" parent="d0"/>
                <mxCell id="dt" value="PostgreSQL Persistence Model and Integrity Boundaries" style="text;html=1;fontSize=24;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="40" y="30" width="650" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="wallet" value="Wallet&#xa;────────────&#xa;uuid UNIQUE&#xa;balance ≥ 0&#xa;reserved_balance ≥ 0&#xa;reserved_balance ≤ balance&#xa;available = balance - reserved" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="-70" y="130" width="240" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="withdrawal" value="Withdrawal&#xa;────────────&#xa;uuid UNIQUE&#xa;wallet FK&#xa;amount &gt; 0&#xa;status + execute_at + queued_at&#xa;bank_idempotency_key UNIQUE&#xa;attempt_count + next_retry_at&#xa;failure / completion metadata" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="430" y="130" width="280" height="270" as="geometry"/>
                </mxCell>
                <mxCell id="ledger" value="Transaction (ledger)&#xa;────────────&#xa;wallet FK&#xa;withdrawal FK nullable&#xa;type + operation&#xa;amount &gt; 0&#xa;balance_after&#xa;UNIQUE(withdrawal, operation)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="80" y="520" width="250" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="attempt" value="BankTransferAttempt&#xa;────────────&#xa;withdrawal FK&#xa;attempt_number&#xa;idempotency_key&#xa;outcome + failure_code&#xa;requested_at + completed_at&#xa;UNIQUE(withdrawal, attempt_number)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="440" y="520" width="280" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="outbox" value="OutboxEvent&#xa;────────────&#xa;withdrawal FK&#xa;event_type&#xa;published_at&#xa;attempt_count&#xa;next_attempt_at + last_error&#xa;INDEX(published_at, next_attempt_at)" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="900" y="180" width="270" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="idempotency" value="ApiIdempotency&#xa;────────────&#xa;key + operation UNIQUE&#xa;request_hash&#xa;response_status&#xa;safe response_body&#xa;created_at" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacingLeft=12;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" parent="d1" vertex="1">
                    <mxGeometry x="830" y="520" width="260" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="de1" value="1 : many" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;html=1;" parent="d1" source="wallet" target="withdrawal" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="de2" value="1 : many" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;html=1;" parent="d1" source="wallet" target="ledger" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="de3" value="1 : many operations" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;html=1;" parent="d1" source="withdrawal" target="ledger" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="de4" value="1 : many attempts" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;html=1;" parent="d1" source="withdrawal" target="attempt" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="de5" value="1 : many events" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERone;html=1;" parent="d1" source="withdrawal" target="outbox" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="note" value="ApiIdempotency is intentionally independent: it stores replay responses for deposit and schedule operations, not a hard FK to one resource type." style="shape=note;whiteSpace=wrap;html=1;fillColor=#fff2cc;" parent="d1" vertex="1">
                    <mxGeometry x="1170" y="520" width="300" height="110" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
