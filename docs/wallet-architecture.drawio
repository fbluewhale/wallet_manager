                    <mxGeometry x="1040" y="500" width="210" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="me1" value="due claim + outbox" style="edgeStyle=orthogonalEdgeStyle;endArrow=block;html=1;" parent="m1" source="scheduled" target="queued" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
