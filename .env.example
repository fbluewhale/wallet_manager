# Copy this file to .env to customize local development ports.
WALLET_PORT=8000
THIRD_PARTY_PORT=8010
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-development-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_MAX_REQUEST_BYTES=1048576
LOG_LEVEL=INFO
DATABASE_URL=postgresql://wallet:wallet@postgres:5432/wallet
REDIS_URL=redis://redis:6379/0
BANK_SERVICE_URL=http://third-party:8010/
BANK_SERVICE_TIMEOUT_SECONDS=5
DISPATCHER_INTERVAL_SECONDS=5
WITHDRAWAL_DISPATCH_BATCH_SIZE=50
WITHDRAWAL_MAX_QUEUED_AGE_SECONDS=60
BANK_RETRY_BASE_SECONDS=5
BANK_RETRY_MAX_SECONDS=300
BANK_MAX_RETRIES=5
